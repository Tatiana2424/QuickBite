{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver,1433;Database=QuickBiteIdentityDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "QuickBite",
    "Audience": "QuickBite.Web",
    "Key": "quickbite-super-secret-development-key-change-me"
  },
  "DatabaseInitialization": {
    "ApplyMigrationsOnStartup": false,
    "SeedDemoData": false,
    "RecreateDatabaseIfMigrationHistoryMissing": false,
    "MigrationRetryCount": 5,
    "MigrationRetryDelaySeconds": 3
  },
  "Kafka": {
    "Enabled": true,
    "ClientId": "quickbite-identity-api",
    "Producer": "QuickBite.Identity.Api",
    "BootstrapServers": "kafka:9092",
    "TopicPartitionCount": 1,
    "TopicReplicationFactor": 1,
    "Consumer": {
      "MaxRetryAttempts": 3,
      "RetryBackoffMilliseconds": 500
    },
    "DeadLetter": {
      "Enabled": true,
      "TopicSuffix": ".dlq"
    },
    "Topics": {
      "OrderCreated": "quickbite.orders.order-created.v1",
      "PaymentSucceeded": "quickbite.payments.payment-succeeded.v1",
      "PaymentFailed": "quickbite.payments.payment-failed.v1",
      "DeliveryAssigned": "quickbite.delivery.delivery-assigned.v1",
      "DeliveryCompleted": "quickbite.delivery.delivery-completed.v1"
    }
  }
}
