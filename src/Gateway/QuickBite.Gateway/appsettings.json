{
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "delivery-route": {
        "ClusterId": "delivery-cluster",
        "Match": {
          "Path": "/delivery/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://quickbite.identity.api:8080/"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://quickbite.catalog.api:8080/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://quickbite.orders.api:8080/"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://quickbite.payments.api:8080/"
          }
        }
      },
      "delivery-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://quickbite.delivery.api:8080/"
          }
        }
      }
    }
  }
}
